{
  "openapi": "3.1.0",
  "info": {
    "title": "Intervals Training API",
    "description": "API for accessing training data and plans from Intervals.icu and local database",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://intervals.stas.run"
    }
  ],
  "paths": {
    "/api/db/user_summary": {
      "get": {
        "summary": "Get user profile and training summary",
        "description": "Returns user's profile information, goals, and training preferences from local database",
        "operationId": "getUserSummary",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID from the system"
          }
        ],
        "responses": {
          "200": {
            "description": "User summary data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "user_summary": {
                      "type": "object",
                      "properties": {
                        "info": {
                          "type": "string"
                        },
                        "goals": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/db/trainings": {
      "get": {
        "summary": "Get user's training sessions",
        "description": "Returns user's completed training sessions from local database",
        "operationId": "getUserTrainings",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID from the system"
          }
        ],
        "responses": {
          "200": {
            "description": "List of training sessions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "trainings": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "date": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "workout_type": {
                            "type": "string"
                          },
                          "distance": {
                            "type": "string"
                          },
                          "training_load": {
                            "type": "number"
                          },
                          "intensity": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/icu/events": {
      "get": {
        "summary": "Get planned workouts from Intervals.icu",
        "description": "Returns user's planned training sessions from Intervals.icu",
        "operationId": "getPlannedWorkouts",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID from the system"
          },
          {
            "name": "oldest",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Oldest date to fetch (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of planned workouts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "start_date": {
                        "type": "string"
                      },
                      "workout_type": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/icu/events/bulk": {
      "post": {
        "summary": "Create new planned workouts in Intervals.icu",
        "description": "Creates new training plans in Intervals.icu",
        "operationId": "createPlannedWorkouts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "start_date": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workouts created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "received": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/healthz": {
      "get": {
        "summary": "Get system health status",
        "description": "Returns aggregated health status of all system components",
        "operationId": "getHealthStatus",
        "responses": {
          "200": {
            "description": "System health status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string"
                    },
                    "services": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string"
                          },
                          "code": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db/activities_full": {
      "get": {
        "summary": "Get user trainings (full payload)",
        "description": "Returns completed training sessions from local database including large jsonb fields (activity_plan, hr_zone_times, interval_summary, splits_km).",
        "operationId": "getUserTrainingsFull",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID from the system"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            },
            "description": "Max items (default 30, max 200)"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            },
            "description": "Offset (default 0)"
          },
          {
            "name": "oldest",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Oldest date (YYYY-MM-DD)"
          },
          {
            "name": "newest",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Newest date (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of training sessions (full payload)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "trainings": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "date": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "workout_type": {
                            "type": "string"
                          },
                          "distance": {
                            "type": "string"
                          },
                          "user_report": {
                            "type": "string"
                          },
                          "ai_comment": {
                            "type": "string"
                          },
                          "training_load": {
                            "type": "number"
                          },
                          "fitness": {
                            "type": "number"
                          },
                          "fatigue": {
                            "type": "number"
                          },
                          "elevation_gain": {
                            "type": "number"
                          },
                          "intensity": {
                            "type": "string"
                          },
                          "icu_hr_zones": {
                            "type": "string"
                          },
                          "avg_heartrate": {
                            "type": "number"
                          },
                          "max_heartrate": {
                            "type": "number"
                          },
                          "lactate_threshold_hr": {
                            "type": "number"
                          },
                          "moving_time": {
                            "type": "string"
                          },
                          "form": {
                            "type": "string"
                          },
                          "user_id": {
                            "type": "integer"
                          },
                          "pace": {
                            "type": "string"
                          },
                          "activity_name": {
                            "type": "string"
                          },
                          "activity_plan": {
                            "type": [
                              "object",
                              "string",
                              "null"
                            ]
                          },
                          "hr_zone_times": {
                            "type": [
                              "array",
                              "string",
                              "null"
                            ]
                          },
                          "interval_summary": {
                            "type": [
                              "array",
                              "null"
                            ]
                          },
                          "splits_km": {
                            "type": [
                              "array",
                              "null"
                            ]
                          },
                          "session_type": {
                            "type": [
                              "string",
                              "null"
                            ]
                          }
                        }
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
