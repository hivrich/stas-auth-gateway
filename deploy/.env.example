# STAS Auth Gateway .env (example)
# Copy to /opt/stas-auth-gateway/.env on the server and fill real secrets.

PORT=3337
NODE_ENV=production

# Gateway talks to the local DB bridge in production.
STAS_BASE=http://127.0.0.1:3336
STAS_INTERNAL_BASE_URL=http://127.0.0.1:3336
STAS_KEY=__SET_IN_ENV__
DB_BRIDGE_API_KEY=__SET_IN_ENV__
STAS_API_KEY=__SET_IN_ENV__
INTERVALS_API_BASE_URL=https://intervals.icu/api/v1
ICU_API_BASE_URL=https://intervals.icu/api/v1
ICU_BASE_URL=https://intervals.icu/api/v1

# PostgreSQL (for gw_oauth_clients)
STAS_PGURL=postgres://USER:PASSWORD@HOST:5432/DB?sslmode=disable

# OAuth (ChatGPT client)
OAUTH_CLIENT_ID=chatgpt-actions
OAUTH_CLIENT_SECRET=<PASTE_NEW_OAUTH_CLIENT_SECRET>
OAUTH_REDIRECTS=https://chat.openai.com/aip/*/oauth/callback

# Crypto / Security
SESSION_SECRET=<random_32+>
JWT_SECRET=<random_32+>
CORS_ORIGINS=*

DEBUG=true

# Token TTLs (seconds)
ACCESS_TTL_SEC=3600
REFRESH_TTL_SEC=2592000
